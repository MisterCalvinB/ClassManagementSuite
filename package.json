{
  "name": "class-management-tools",
  "version": "1.0.0",
  "private": true,
  "description": "Electron shell for the teaching tools.",
  "author": "Arnaud Barras (https://github.com/MisterCalvinB/ClassManagementSuite)",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "server": "node js/classroom-server.js",
    "quiz:server": "node js/classroom-server.js",
    "package:win-portable": "electron-builder --win portable --x64 --config.directories.output=dist/win-portable",
    "package:win-installer": "electron-builder --win nsis --x64",
    "package:linux-portable": "powershell -ExecutionPolicy Bypass -File .\\package-linux-appimage-windows-exe.ps1",
    "package:linux-appimage": "powershell -ExecutionPolicy Bypass -File .\\package-linux-appimage-windows-exe.ps1",
    "package:linux-appimage:local": "electron-builder --linux AppImage --x64",
    "package:linux": "npm run package:linux-appimage",
    "package:windows": "npm run package:win-portable",
    "package:win-portable-only": "electron-builder --win portable --x64 --config.directories.output=dist/win-portable",
    "package:mac": "bash ./package-mac.sh",
    "package:mac-arm": "bash ./package-mac.sh --arm64"
  },
  "build": {
    "appId": "com.classmanagementtools",
    "productName": "Class Management Tools",
    "icon": "build/icon.png",
    "asar": true,
    "artifactName": "class-management-tools-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist/appimage"
    },
    "files": [
      "launcher.html",
      "*.js",
      "pages/**/*.html",
      "css/**/*",
      "js/**/*",
      "data/**/*",
      "modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Education"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.education"
    }
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^24.13.3",
    "pdfjs-dist": "^5.7.284",
    "playwright-core": "^1.60.0",
    "xlsx": "^0.18.5"
  },
  "dependencies": {
    "@fontsource/lexend": "^5.2.11",
    "basic-ftp": "^6.0.1",
    "docx": "^8.5.0",
    "googleapis": "^173.0.0",
    "katex": "^0.17.0",
    "marked": "^18.0.5",
    "monaco-editor": "^0.55.1",
    "pdf2image": "^1.2.3",
    "webdav": "^5.10.0",
    "ws": "^8.18.0"
  }
}
